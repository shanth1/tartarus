ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

OPENCODE_API_KEY=
OPENCODE_GO_API_KEY=
OPENCODE_ZEN_API_KEY=

# open-source & inference APIs
